# picblobs Bazel configuration

# Build settings
build --incompatible_enable_cc_toolchain_resolution
build --action_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1

# Freestanding C compilation defaults (applied via toolchain, listed here for reference)
# -ffreestanding -nostdlib -nostartfiles -fno-builtin -fPIC
# -ffunction-sections -fdata-sections -Os -Wall -Werror

# Linker: dead-code elimination is handled by the toolchain config
# via -Wl,--gc-sections (not --linkopt, which bypasses gcc driver).

# Strict sandbox
build --sandbox_default_allow_network=false

# Reproducibility
build --stamp=false
build --nolegacy_external_runfiles

# Remote caching (uncomment and configure for CI)
# build --remote_cache=grpcs://cache.example.com

# Platform configs — use with: bazel build --config=linux_x86_64 //...
# BEGIN GENERATED PLATFORM CONFIGS
build:linux_x86_64          --platforms=//platforms:linux_x86_64 --define=PICBLOBS_TARGET_OS=linux
build:linux_i686            --platforms=//platforms:linux_i686 --define=PICBLOBS_TARGET_OS=linux
build:linux_aarch64         --platforms=//platforms:linux_aarch64 --define=PICBLOBS_TARGET_OS=linux
build:linux_armv5_arm       --platforms=//platforms:linux_armv5_arm --define=PICBLOBS_TARGET_OS=linux
build:linux_armv5_thumb     --platforms=//platforms:linux_armv5_thumb --define=PICBLOBS_TARGET_OS=linux
build:linux_armv7_thumb     --platforms=//platforms:linux_armv7_thumb --define=PICBLOBS_TARGET_OS=linux
build:linux_s390x           --platforms=//platforms:linux_s390x --define=PICBLOBS_TARGET_OS=linux
build:linux_mipsel32        --platforms=//platforms:linux_mipsel32 --define=PICBLOBS_TARGET_OS=linux
build:linux_mipsbe32        --platforms=//platforms:linux_mipsbe32 --define=PICBLOBS_TARGET_OS=linux
build:linux_sparcv8         --platforms=//platforms:linux_sparcv8 --define=PICBLOBS_TARGET_OS=linux
build:linux_powerpc         --platforms=//platforms:linux_powerpc --define=PICBLOBS_TARGET_OS=linux
build:linux_ppc64le         --platforms=//platforms:linux_ppc64le --define=PICBLOBS_TARGET_OS=linux
build:linux_riscv64         --platforms=//platforms:linux_riscv64 --define=PICBLOBS_TARGET_OS=linux

build:freebsd_x86_64        --platforms=//platforms:freebsd_x86_64 --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_i686          --platforms=//platforms:freebsd_i686 --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_aarch64       --platforms=//platforms:freebsd_aarch64 --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_armv5_arm     --platforms=//platforms:freebsd_armv5_arm --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_armv5_thumb   --platforms=//platforms:freebsd_armv5_thumb --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_armv7_thumb   --platforms=//platforms:freebsd_armv7_thumb --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_mipsel32      --platforms=//platforms:freebsd_mipsel32 --define=PICBLOBS_TARGET_OS=freebsd
build:freebsd_mipsbe32      --platforms=//platforms:freebsd_mipsbe32 --define=PICBLOBS_TARGET_OS=freebsd

build:windows_x86_64        --platforms=//platforms:windows_x86_64 --define=PICBLOBS_TARGET_OS=windows
build:windows_i686          --platforms=//platforms:windows_i686 --define=PICBLOBS_TARGET_OS=windows
build:windows_aarch64       --platforms=//platforms:windows_aarch64 --define=PICBLOBS_TARGET_OS=windows
# END GENERATED PLATFORM CONFIGS

# Build mode configs — orthogonal to platform, composable.
#   bazel build //release:full --config=linux_x86_64 --config=debug
#   bazel build //release:full --config=linux_x86_64 --config=release
build:debug   --copt=-g --copt=-DPIC_LOG_ENABLE
build:debug   --strip=never

build:release --strip=always

# Lint config
build:lint --aspects=//bazel:lint.bzl%clang_tidy_aspect
build:lint --output_groups=lint_results

# Test settings
test --test_output=errors
test --test_verbose_timeout_warnings
test --test_env=PATH

# CI settings
build:ci --config=lint
build:ci --action_env=PICBLOBS_REQUIRE_LINT_TOOLS=1
test:ci --test_env=PICBLOBS_REQUIRE_LINT_TOOLS=1
# Only effective with remote cache enabled (see --remote_cache above).
build:ci --remote_download_minimal
test:ci --test_output=all
